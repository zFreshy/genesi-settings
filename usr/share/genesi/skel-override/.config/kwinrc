[Windows]
BorderlessMaximizedWindows=false
RollOverDesktops=true

[Xwayland]
Scale=1

[org.kde.kdecoration2]
BorderSize=Normal
BorderSizeAuto=false
ButtonsOnLeft=MFS
ButtonsOnRight=HIAX
library=org.kde.klassy
theme=Klassy

[Plugins]
blurEnabled=true
contrastEnabled=true
forceblurEnabled=true
kwin4_effect_translucencyEnabled=true
# slidingPopups makes Kickoff visibly "grow" from nothing to its final
# size on every open - user reported this as the "fica crescendo" bug
# (2026-05-29). Disabling the effect makes popups appear instantly at
# their target dimensions while keeping everything else (blur, contrast,
# translucency, sheet, dim, squash). Verified live: turning this off
# eliminated the grow effect on Kickoff without touching anything else.
slidingPopupsEnabled=false
sheetEnabled=true
translucencyEnabled=true
kwin4_effect_dimscreenEnabled=true
kwin4_effect_squashEnabled=true

[Effect-Blur]
BlurStrength=9
NoiseStrength=3

# Better Blur (forceblur) — the effect Genesi actually uses (forceblurEnabled=
# true). Its config lives in the lowercase [Effect-blur] group. Without it the
# effect defaults to Saturation=255 (max), which over-saturates the wallpaper
# blurred behind translucent titlebars and made them look vivid green.
[Effect-blur]
BlurStrength=4
NoiseStrength=0
Saturation=127

# The SINGLE source of Genesi's window glass. Windows are painted fully opaque
# now (the color scheme + klassyrc carry no alpha), so this compositor effect —
# applied window-wide, titlebar and body together — is what makes them
# see-through, and forceblur frosts it. Decoration is kept equal to ActiveOpacity
# so the titlebar fades by the same amount as the body (uniform, no lighter
# titlebar). Because it's a compositor effect it toggles LIVE for every window
# (open or new): the AI Mode kwin helper unloads it (with blur/contrast) and the
# whole desktop snaps fully opaque instantly — no blur, no transparency — then
# back to glass when AI Mode turns off. Tune ActiveOpacity for more/less glass.
[Effect-Translucency]
ActiveOpacity=82
InactiveOpacity=78
Decoration=82
Dialogs=90
DialogsInactive=85
MenuOpacity=92
MoveResize=85
InMoveResize=82

[Compositing]
Backend=OpenGL
Enabled=true
GLCore=true
GLPreferBufferSwap=a
GLTextureFilter=2
HiddenPreviews=5
OpenGLIsUnsafe=false
WindowsBlockCompositing=false
XRenderSmoothScale=false

[TabBox]
LayoutName=thumbnail_grid

[Effect-PresentWindows]
BorderActivate=9

[Effect-DesktopGrid]
BorderActivate=9

[ModifierOnlyShortcuts]
Meta=org.kde.plasmashell,/PlasmaShell,org.kde.PlasmaShell,activateLauncherMenu

[Desktops]
Number=1
Rows=1
